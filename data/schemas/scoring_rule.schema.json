{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "doc_type",
    "role",
    "title",
    "tags",
    "applicable_features",
    "sections",
    "category",
    "subcategory",
    "difficulty"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "doc_type": {
      "const": "scoring"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "applicable_features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "sections": {
      "type": "object",
      "required": [
        "summary",
        "key_points",
        "usage"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "key_points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "usage": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "subcategory": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "minLength": 1
    }
  }
}