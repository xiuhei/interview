# =============================================================================
# AI 模拟面试平台 - 环境变量配置
# =============================================================================
# 使用方法: 复制为 .env 并填入实际值
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础配置
# -----------------------------------------------------------------------------
APP_NAME=AI 模拟面试平台
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=dev-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# -----------------------------------------------------------------------------
# Docker 构建镜像源（可选）
# -----------------------------------------------------------------------------

# 官方镜像源
# PYTHON_BASE_IMAGE=python:3.12-slim
# NODE_BASE_IMAGE=node:24-alpine
# MYSQL_IMAGE=mysql:8.4
# REDIS_IMAGE=redis:7.4-alpine
# ETCD_IMAGE=quay.io/coreos/etcd:v3.5.5
# MINIO_IMAGE=minio/minio:RELEASE.2024-12-18T13-15-44Z
# MILVUS_IMAGE=milvusdb/milvus:v2.5.4
# NGINX_IMAGE=nginx:1.27-alpine

PYTHON_BASE_IMAGE=docker.m.daocloud.io/python:3.12-slim
NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:24-alpine
MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.4-alpine
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.5
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2024-12-18T13-15-44Z
MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.5.4
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine

# -----------------------------------------------------------------------------
# 数据库配置（本地开发使用 localhost，Docker 部署时由 compose 覆盖）
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=interview
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/interview?charset=utf8mb4

REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=interview_kb_chunks
MILVUS_TOKEN=

# -----------------------------------------------------------------------------
# Qwen 模型配置（LLM / Embedding / ASR / TTS 共用）
# -----------------------------------------------------------------------------
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_API_KEY=
QWEN_LLM_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_DIMENSION=512
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE=Chinese
TTS_FORMAT=wav

# -----------------------------------------------------------------------------
# 面试参数配置
# -----------------------------------------------------------------------------
DEFAULT_QUESTION_COUNT=6
MIN_QUESTION_COUNT=5
MAX_QUESTION_COUNT=8
RETRIEVAL_TOP_K=6
INTERVIEW_CONTEXT_TURNS=3
UPLOAD_DIR_NAME=var/uploads
CONTENT_SOURCE_DIR_NAME=data/content_source
RUNTIME_CORPUS_DIR_NAME=data/runtime_corpus
BUILD_ARTIFACTS_DIR_NAME=data/build_artifacts
LOG_DIR_NAME=var/logs
LOG_LEVEL=INFO
